{
  "ReverseProxy": {
    "Routes": {
      "routeA": {
        "ClusterId": "clusterA",
        "Match": {
          "Path": "/a/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/a" }
        ]
      }
    },
    "Clusters": {
      "clusterA": {
        "Destinations": {
          "dest1": {
            "Address": "http://localhost:5001/"
          }
        }
      }
    }
  }
}