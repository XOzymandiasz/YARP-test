{
  "ReverseProxy": {
    "Routes": {
      "routeA": {
        "ClusterId": "clusterA",
        "Match": {
          "Path": "/a/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/a" }
        ]
      },
      "routeB": {
        "ClusterId": "clusterB",
        "Match": {
          "Path": "/b/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/b" }
        ]
      },
      "routeLb": {
        "ClusterId": "clusterLb",
        "Match": {
          "Path": "/lb/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/lb" }
        ]
      }
    },
    "Clusters": {
      "clusterA": {
        "Destinations": {
          "dest1": {
            "Address": "http://backend-a:8080/"
          }
        }
      },
      "clusterB": {
        "Destinations": {
          "dest1": {
            "Address": "http://backend-b:8080/"
          }
        }
      },
      "clusterLb": {
        "Destinations": {
          "dest1": {
            "Address": "http://backend-a:8080/"
          },
          "dest2": {
            "Address": "http://backend-b:8080/"
          }
        }
      }
    }
  }
}